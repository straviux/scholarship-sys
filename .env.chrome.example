# Chrome Configuration for PDF Generation
# 
# The application uses Spatie/Browsershot to generate PDFs for reports and OBR documents.
# Chrome/Chromium is required for this functionality.
#
# Option 1: Let Browsershot auto-detect (RECOMMENDED for most servers)
# Leave CHROME_PATH unset or empty - Browsershot will find Chrome automatically
#
# Option 2: Specify Chrome path explicitly
# Set the full path to your Chrome/Chromium executable:
#
# For Linux/Mac:
# CHROME_PATH=/usr/bin/google-chrome
# CHROME_PATH=/Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome
#
# For Windows:
# CHROME_PATH=C:\\Program Files\\Google\\Chrome\\Application\\chrome.exe
# CHROME_PATH=C:\\Program Files (x86)\\Google\\Chrome\\Application\\chrome.exe

CHROME_PATH=

# Optional: Timeout for PDF generation (in seconds)
BROWSERSHOT_TIMEOUT=120

# Optional: Run Chrome in headless mode (recommended for production)
BROWSERSHOT_HEADLESS=true
